<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Naki</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;700&family=Shippori+Mincho:wght@400;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #f5f0e8;
    font-family: 'Noto Serif JP', serif;
    min-height: 100vh;
    overflow-x: hidden;
    color: #1a1a1a;
  }

  /* Sakura petals */
  .petals-container {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .petal {
    position: absolute;
    top: -30px;
    width: 12px;
    height: 12px;
    opacity: 0;
    animation: fall linear infinite;
  }

  .petal svg { width: 100%; height: 100%; }

  @keyframes fall {
    0%   { transform: translateY(0) rotate(0deg); opacity: 0.8; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }

  /* Vertical red line left */
  .red-line {
    position: fixed;
    left: 48px;
    top: 0;
    width: 2px;
    height: 100vh;
    background: #c0392b;
    z-index: 1;
  }

  /* Main content */
  .wrapper {
    position: relative;
    z-index: 2;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 80px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  /* Hero section */
  .hero {
    padding: 80px 0 60px;
  }

  .kana {
    font-size: 13px;
    letter-spacing: 0.4em;
    color: #c0392b;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-family: 'Noto Serif JP', serif;
    font-weight: 300;
  }

  .name {
    font-family: 'Shippori Mincho', serif;
    font-size: clamp(64px, 10vw, 112px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    color: #1a1a1a;
    position: relative;
  }

  .name .accent {
    color: #c0392b;
  }

  .japanese-name {
    font-family: 'Noto Serif JP', serif;
    font-size: 22px;
    font-weight: 300;
    color: #888;
    letter-spacing: 0.3em;
    margin-top: 10px;
  }

  .divider {
    width: 60px;
    height: 1px;
    background: #c0392b;
    margin: 32px 0;
  }

  .tagline {
    font-family: 'Noto Serif JP', serif;
    font-size: 15px;
    font-weight: 300;
    color: #555;
    letter-spacing: 0.15em;
    line-height: 2;
    max-width: 380px;
  }

  /* Buttons */
  .links {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 52px;
  }

  .link-btn {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 28px;
    background: transparent;
    border: 1px solid #c8bfb0;
    text-decoration: none;
    color: #1a1a1a;
    font-family: 'Noto Serif JP', serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.2em;
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
    width: 280px;
  }

  .link-btn::before {
    content: '';
    position: absolute;
    left: 0; top: 0;
    width: 3px;
    height: 100%;
    background: #c0392b;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s ease;
  }

  .link-btn:hover::before { transform: scaleY(1); }

  .link-btn:hover {
    background: rgba(192, 57, 43, 0.04);
    border-color: #c0392b;
    padding-left: 36px;
  }

  .link-btn .icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .link-btn .label {
    flex: 1;
  }

  .link-btn .arrow {
    font-size: 18px;
    color: #c0392b;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s ease;
  }

  .link-btn:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Seal / stamp decoration */
  .seal {
    position: fixed;
    right: 60px;
    bottom: 60px;
    width: 80px;
    height: 80px;
    z-index: 2;
    opacity: 0.85;
  }

  /* Vertical text right side */
  .vertical-text {
    position: fixed;
    right: 32px;
    top: 50%;
    transform: translateY(-50%) rotate(90deg);
    font-family: 'Noto Serif JP', serif;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.4em;
    color: #bbb;
    white-space: nowrap;
    z-index: 2;
  }

  /* Ink wash bg */
  .ink-bg {
    position: fixed;
    right: -80px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 0;
    opacity: 0.04;
    pointer-events: none;
  }
</style>
</head>
<body>

<!-- Sakura petals -->
<div class="petals-container" id="petals"></div>

<!-- Left red line -->
<div class="red-line"></div>

<!-- Vertical text -->
<div class="vertical-text">流れる夢　・　streaming dreams</div>

<!-- Ink wash background kanji -->
<svg class="ink-bg" width="500" height="500" viewBox="0 0 500 500">
  <text x="50%" y="55%" text-anchor="middle" font-family="Noto Serif JP, serif" font-size="460" font-weight="700" fill="#1a1a1a">泣</text>
</svg>

<!-- Main -->
<div class="wrapper">
  <section class="hero">
    <p class="kana">ナキ &nbsp;·&nbsp; streamer</p>
    <h1 class="name">Na<span class="accent">ki</span></h1>
    <p class="japanese-name">泣 き</p>
    <div class="divider"></div>
    <p class="tagline">Bienvenue sur mon espace.<br>Rejoins la communauté, suis le stream,<br>et vivons ça ensemble.</p>

    <nav class="links">

      <!-- Twitch -->
      <a class="link-btn" href="https://www.twitch.tv/na_ki__" target="_blank" rel="noopener">
        <svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4.5 2L3 5.5V20H7.5V22.5H10.5L13 20H16.5L21 15.5V2H4.5Z" stroke="#9146FF" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M10 7V13M15 7V13" stroke="#9146FF" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="label">Twitch</span>
        <span class="arrow">→</span>
      </a>

      <!-- Discord -->
      <a class="link-btn" href="https://discord.gg/CD5q6HzD" target="_blank" rel="noopener">
        <svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 11.5C9 12.33 8.33 13 7.5 13C6.67 13 6 12.33 6 11.5C6 10.67 6.67 10 7.5 10C8.33 10 9 10.67 9 11.5Z" fill="#5865F2"/>
          <path d="M18 11.5C18 12.33 17.33 13 16.5 13C15.67 13 15 12.33 15 11.5C15 10.67 15.67 10 16.5 10C17.33 10 18 10.67 18 11.5Z" fill="#5865F2"/>
          <path d="M20.317 4.492C18.787 3.776 17.147 3.249 15.432 2.999C15.212 3.399 14.952 3.939 14.772 4.369C12.952 4.099 11.147 4.099 9.361 4.369C9.181 3.939 8.912 3.399 8.691 2.999C6.975 3.249 5.334 3.777 3.803 4.494C0.795 9.093 -0.008 13.578 0.402 18C2.522 19.558 4.58 20.488 6.606 21.099C7.106 20.399 7.553 19.659 7.937 18.879C7.197 18.599 6.486 18.249 5.816 17.839C5.996 17.709 6.172 17.574 6.342 17.434C10.272 19.274 14.565 19.274 18.447 17.434C18.619 17.574 18.795 17.709 18.973 17.839C18.302 18.25 17.59 18.601 16.849 18.881C17.233 19.661 17.679 20.401 18.18 21.101C20.207 20.49 22.267 19.56 24.386 18C24.872 12.867 23.519 8.423 20.317 4.492Z" stroke="#5865F2" stroke-width="0.5"/>
        </svg>
        <span class="label">Discord</span>
        <span class="arrow">→</span>
      </a>

    </nav>
  </section>
</div>

<!-- Seal stamp -->
<svg class="seal" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
  <rect x="4" y="4" width="72" height="72" fill="none" stroke="#c0392b" stroke-width="2"/>
  <rect x="9" y="9" width="62" height="62" fill="none" stroke="#c0392b" stroke-width="0.5"/>
  <text x="40" y="52" text-anchor="middle" font-family="Noto Serif JP, serif" font-size="38" font-weight="700" fill="#c0392b">泣</text>
</svg>

<script>
  // Generate sakura petals
  const container = document.getElementById('petals');
  const colors = ['#f4a7b9', '#f9c5d0', '#e8a0b0', '#f7d0da', '#fce4ec'];

  for (let i = 0; i < 18; i++) {
    const petal = document.createElement('div');
    petal.className = 'petal';
    const left = Math.random() * 100;
    const duration = 8 + Math.random() * 10;
    const delay = Math.random() * 12;
    const size = 8 + Math.random() * 10;
    const color = colors[Math.floor(Math.random() * colors.length)];

    petal.style.cssText = `
      left: ${left}%;
      animation-duration: ${duration}s;
      animation-delay: ${delay}s;
      width: ${size}px;
      height: ${size}px;
    `;

    petal.innerHTML = `<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="10" cy="6" rx="5" ry="7" fill="${color}" opacity="0.85" transform="rotate(0,10,10)"/>
      <ellipse cx="14" cy="12" rx="5" ry="7" fill="${color}" opacity="0.75" transform="rotate(72,10,10)"/>
      <ellipse cx="7" cy="16" rx="5" ry="7" fill="${color}" opacity="0.8" transform="rotate(144,10,10)"/>
      <ellipse cx="3" cy="9" rx="5" ry="7" fill="${color}" opacity="0.7" transform="rotate(216,10,10)"/>
      <ellipse cx="10" cy="5" rx="5" ry="7" fill="${color}" opacity="0.75" transform="rotate(288,10,10)"/>
    </svg>`;

    container.appendChild(petal);
  }
</script>
</body>
</html>
